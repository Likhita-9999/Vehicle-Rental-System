        } else if (n1 == 3) {
            System.out.println("The price for Vespa scooty is per hour is 300/-");
            System.out.println("Enter number of hours you want");
            float h3 = sc.nextFloat();
            price_per_hour1 = h3 * 300;
            System.out.println("Total amount to be payed is :" + (price_per_hour1));
        } else if (n1 == 4) {
            System.out.println("The price for Ather energy(EV) scooty is per hour is 350/-");
            System.out.println("Enter number of hours you want");
            float h4 = sc.nextFloat();
